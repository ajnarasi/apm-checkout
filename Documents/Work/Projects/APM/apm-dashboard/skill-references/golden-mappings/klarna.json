{
  "goldenMapping": {
    "apmId": "KLARNA",
    "apmDisplayName": "Klarna",
    "pattern": "server-bnpl",
    "patternVersion": "v1",
    "source": "sandbox-validated-mapping",
    "verifiedBy": "Sandbox API validation",
    "verifiedDate": "2026-04-12",
    "commerceHubVersion": "1.26.0302",
    "providerApiVersion": "v1",
    "category": "BNPL",
    "regions": ["US", "CA", "UK", "DE", "FR", "NL", "BE", "AT", "CH", "ES", "IT", "PT", "SE", "NO", "DK", "FI"],
    "currencies": ["USD", "CAD", "GBP", "EUR", "SEK", "NOK", "DKK", "CHF"],
    "capabilities": ["auth", "capture", "partial-refund", "cancel"]
  },

  "endpoints": {
    "sessionCreate": {
      "chEndpoint": "POST /checkouts/v1/orders",
      "providerEndpoint": "POST /payments/v1/sessions",
      "description": "Create Klarna payment session — initializes checkout with order details and line items",
      "authFormat": "HTTP Basic: Base64(username:password)",
      "verified": true,
      "sandboxValidated": "2026-04-12"
    },
    "auth": {
      "chEndpoint": "POST /checkouts/v1/orders",
      "providerEndpoint": "POST /payments/v1/authorizations/{auth_token}/order",
      "description": "Place order after customer authorizes via Klarna widget"
    },
    "capture": {
      "chEndpoint": "POST /checkouts/v1/orders",
      "providerEndpoint": "POST /ordermanagement/v1/orders/{order_id}/captures",
      "description": "Capture a previously authorized Klarna order"
    },
    "partialRefund": {
      "chEndpoint": "POST /checkouts/v1/orders",
      "providerEndpoint": "POST /ordermanagement/v1/orders/{order_id}/refunds",
      "description": "Refund (full or partial) a captured Klarna order"
    },
    "cancel": {
      "chEndpoint": "POST /checkouts/v1/orders",
      "providerEndpoint": "POST /ordermanagement/v1/orders/{order_id}/cancel",
      "description": "Cancel an authorized but uncaptured Klarna order"
    }
  },

