  "responseMappings": {
    "sessionCreate": [
      {
        "id": "SRES_001",
        "apmField": "session_id",
        "apmFieldType": "string",
        "chField": "order.providerOrderId",
        "chFieldType": "string",
        "transform": "PASS_THROUGH",
        "tier": 1,
        "description": "Klarna session ID — serves as the provider order identifier"
      },
      {
        "id": "SRES_002",
        "apmField": "client_token",
        "apmFieldType": "string",
        "chField": "paymentMethod.paymentToken.tokenData",
        "chFieldType": "string",
        "transform": "PASS_THROUGH",
        "tier": 1,
        "description": "Client token for Klarna JS SDK initialization"
      },
      {
        "id": "SRES_003",
        "apmField": "payment_method_categories[].identifier",
        "apmFieldType": "string",
        "chField": "paymentMethod.type",
        "chFieldType": "string",
        "transform": "PASS_THROUGH",
        "tier": 2,
        "description": "Available Klarna payment method types (pay_later, pay_over_time, etc.)"
      }
    ],
    "auth": [
      {
        "id": "ARES_001",
        "apmField": "order_id",
        "apmFieldType": "string",
        "chField": "transactionProcessingDetails.transactionId",
        "chFieldType": "string",
        "transform": "PASS_THROUGH",
        "tier": 1,
        "description": "Klarna order ID — used for capture, refund, cancel"
      },
      {
        "id": "ARES_002",
        "apmField": "fraud_status",
        "apmFieldType": "string",
        "chField": "gatewayResponse.transactionState",
        "chFieldType": "string",
        "transform": "ENUM_MAP",
        "transformMap": {
          "ACCEPTED": "AUTHORIZED",
          "PENDING": "PENDING",
          "REJECTED": "DECLINED"
        },
        "tier": 1,
        "description": "Klarna fraud/risk decision mapped to CH transaction state"
      },
      {
        "id": "ARES_003",
        "apmField": "authorized_payment_method.type",
        "apmFieldType": "string",
        "chField": "paymentMethod.type",
        "chFieldType": "string",
        "transform": "PASS_THROUGH",
        "tier": 2,
        "description": "Which Klarna product the customer selected"
      }
    ],
    "capture": [
      {
        "id": "CRES_001",
        "apmField": "capture_id",
        "apmFieldType": "string",
        "chField": "paymentReceipt.processorResponseDetails.referenceNumber",
        "chFieldType": "string",
        "transform": "PASS_THROUGH",
        "tier": 1,
        "description": "Klarna capture ID"
      },
      {
        "id": "CRES_002",
        "apmField": "captured_amount",
        "apmFieldType": "integer",
        "chField": "paymentReceipt.approvedAmount.total",
        "chFieldType": "number",
        "transform": "CENTS_TO_DECIMAL",
        "tier": 1,
        "description": "Captured amount converted to decimal"
      }
    ],
    "partialRefund": [
      {
        "id": "RRES_001",
        "apmField": "refund_id",
        "apmFieldType": "string",
        "chField": "paymentReceipt.processorResponseDetails.referenceNumber",
        "chFieldType": "string",
        "transform": "PASS_THROUGH",
        "tier": 1,
        "description": "Klarna refund ID"
      },
      {
        "id": "RRES_002",
        "apmField": "refunded_amount",
        "apmFieldType": "integer",
        "chField": "paymentReceipt.approvedAmount.total",
        "chFieldType": "number",
        "transform": "CENTS_TO_DECIMAL",
        "tier": 1,
        "description": "Refunded amount converted to decimal"
      }
    ]
  },

  "authScheme": {
    "type": "HTTP_BASIC",
    "description": "Klarna uses HTTP Basic authentication with Base64(username:password)",
    "credentialFields": {
      "username": "API Username (UUID format)",
      "password": "API Password (klarna_test_api_... format)"
    },
    "headerFormat": "Authorization: Basic {Base64(username:password)}"
  },

  "lifecycle": {
    "supportedOperations": ["auth", "capture", "partial-refund", "cancel"],
    "unsupportedOperations": ["void", "incremental-auth"],
    "stateMapping": {
      "SESSION_CREATED": "PAYER_ACTION_REQUIRED",
      "AUTHORIZED": "AUTHORIZED",
      "PART_CAPTURED": "PARTIALLY_CAPTURED",
      "CAPTURED": "CAPTURED",
      "REFUNDED": "REFUNDED",
      "CANCELLED": "VOIDED",
      "EXPIRED": "EXPIRED"
    },
    "flow": "SESSION_CREATE → CUSTOMER_AUTHORIZES (widget) → PLACE_ORDER → CAPTURE → REFUND/CANCEL"
  },

  "safetyChecks": {
    "amountSymmetry": {
      "requestTransform": "DECIMAL_TO_CENTS (×100)",
      "responseTransform": "CENTS_TO_DECIMAL (÷100)",
      "symmetric": true,
      "status": "PASS"
    },
    "currencyPreservation": {
      "requestField": "purchase_currency (pass-through)",
      "status": "PASS"
    },
    "tier1Coverage": {
      "allTier1FieldsMapped": true,
      "status": "PASS"
    },
    "bnplLineItemCheck": {
      "orderLinesRequired": true,
      "orderLineFieldsCovered": ["name", "quantity", "unit_price", "total_amount", "total_tax_amount"],
      "status": "PASS"
    }
  },

  "sandboxFidelity": {
    "knownDiscrepancies": [
      {
        "field": "order_lines[]",
        "sandbox": "May accept requests without detailed line items",
        "production": "Enforces order_lines[] with name, quantity, unit_price, total_amount, total_tax_amount as required",
        "risk": "HIGH — BNPL mapping must always include line items"
      },
      {
        "field": "shipping_address",
        "sandbox": "Accepts without shipping address",
        "production": "May require shipping address for physical goods orders",
        "risk": "MEDIUM — conditional on product type"
      }
    ]
  },

  "bnplSpecificFields": {
    "note": "These Tier 2 fields are promoted to Tier 1 for BNPL pattern",
    "promotedFields": [
      "orderData.itemDetails[]",
      "shippingAddress",
      "billingAddress",
      "customer.email",
      "amountComponents.taxAmounts"
    ]
  }
}
