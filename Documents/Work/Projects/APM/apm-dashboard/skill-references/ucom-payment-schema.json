    "Credit": {
      "type": "object",
      "description": "Information on a credit account",
      "fields": [
        { "name": "cardNumber", "type": "string", "required": false, "description": "Primary account number, can only be sent when vaulting an account. NOT present in responses.", "example": "4111111111111111" },
        { "name": "bin", "type": "string", "required": false, "description": "Bank Identification Number" },
        { "name": "nameOnCard", "type": "string", "required": false, "description": "Name as printed on physical card or on virtual account", "example": "John Smith" },
        { "name": "alias", "type": "string", "required": false, "readOnly": true, "description": "Last four values of the cardNumber", "example": "1111" },
        { "name": "cardType", "type": "CreditCardType", "required": false, "description": "Indicates the type of credit account association.", "enum": ["AMEX", "DISCOVER", "MASTERCARD", "PLCC", "VISA", "OTHER"] },
