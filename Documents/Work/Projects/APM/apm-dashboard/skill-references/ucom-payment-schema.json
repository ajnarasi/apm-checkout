{
  "platform": "uCom Payment Services",
  "version": "0.2.3",
  "baseUrl": "https://int.api.firstdata.com/ucom",
  "auth": {
    "headers": [
      {
        "name": "Api-Key",
        "required": true,
        "description": "An API key string value passed by a client app to the API proxies. Uniquely identifies the client app."
      },
      {
        "name": "Timestamp",
        "required": true,
        "description": "Epoch timestamp in the request initiating system"
      },
      {
        "name": "Authorization",
        "required": true,
        "description": "Authorization information for the request. Format: HMAC {hmacToken}"
      },
      {
        "name": "Client-Request-Id",
        "required": false,
        "description": "Unique ID generated by the client for enforcing idempotency on POST actions."
      },
      {
        "name": "Client-Token",
        "required": false,
        "description": "Used to pass original client OAuth token in a client-credentials flow. Format: Bearer {access_token}"
      }
    ]
  },
  "endpoints": {
    "createAuth": {
      "method": "POST",
      "path": "/v1/payments/auths",
      "description": "Create a payment authorization. Must include a funding source, authorization type and requested amount greater than 0.",
      "requestSchema": "AuthRequest",
      "responseSchema": "Authorization"
    },
    "getAuthByClientRequestId": {
      "method": "GET",
      "path": "/v1/payments/auths",
      "description": "Fetch details of a payment authorization by clientRequestId",
      "responseSchema": "Authorization"
    },
    "getAuthById": {
      "method": "GET",
      "path": "/v1/payments/auths/{fdAuthorizationId}",
      "description": "Fetch details of a payment authorization by authorizationId",
      "responseSchema": "Authorization"
    },
    "voidAuth": {
      "method": "POST",
      "path": "/v1/payments/auths/{fdAuthorizationId}/void",
      "description": "Used to void the payment authorization.",
      "requestSchema": "VoidRequest",
      "responseSchema": "Authorization"
    },
    "captureAuth": {
      "method": "POST",
      "path": "/v1/payments/auths/{fdAuthorizationId}/captures",
      "description": "Capture aka fulfill a previous authorization.",
      "requestSchema": "CaptureRequest",
      "responseSchema": "Capture"
    },
    "refundAuth": {
      "method": "POST",
      "path": "/v1/payments/auths/{fdAuthorizationId}/refunds",
      "description": "Execute a refund on a payment authorization.",
      "requestSchema": "RefundRequest",
      "responseSchema": "Refund"
    },
    "getCaptureByClientRequestId": {
      "method": "GET",
      "path": "/v1/payments/captures",
      "description": "Fetch captured payment details with a clientRequestId",
      "responseSchema": "Capture"
    },
    "getCaptureById": {
      "method": "GET",
      "path": "/v1/payments/captures/{fdCaptureId}",
      "description": "Fetch captured payment details with a capture id.",
      "responseSchema": "Capture"
    },
    "voidCapture": {
      "method": "POST",
      "path": "/v1/payments/captures/{fdCaptureId}/void",
      "description": "Used to void the capture.",
      "requestSchema": "VoidRequest",
      "responseSchema": "Capture"
    },
    "refundCapture": {
      "method": "POST",
      "path": "/v1/payments/captures/{fdCaptureId}/refunds",
      "description": "Refund a capture.",
      "requestSchema": "RefundRequest",
      "responseSchema": "Refund"
    },
    "createSale": {
      "method": "POST",
      "path": "/v1/payments/sales",
      "description": "Create a payment sale transaction. Must include a funding source and requested amount greater than 0.",
      "requestSchema": "SaleRequest",
      "responseSchema": "Sale"
    },
    "getSaleByClientRequestId": {
      "method": "GET",
      "path": "/v1/payments/sales",
      "description": "Fetch a Sale detail object",
      "responseSchema": "Sale"
    },
    "getSaleById": {
      "method": "GET",
      "path": "/v1/payments/sales/{fdSaleId}",
      "description": "Fetch a Sale detail object by saleId",
      "responseSchema": "Sale"
    },
    "voidSale": {
      "method": "POST",
      "path": "/v1/payments/sales/{fdSaleId}/void",
      "description": "Used to cancel or void a sale transaction.",
      "requestSchema": "VoidRequest",
      "responseSchema": "Sale"
    },
    "refundSale": {
      "method": "POST",
      "path": "/v1/payments/sales/{fdSaleId}/refunds",
      "description": "Refund a sale transaction.",
      "requestSchema": "RefundRequest",
      "responseSchema": "Refund"
    },
    "getRefundByClientRequestId": {
      "method": "GET",
      "path": "/v1/payments/refunds",
      "description": "Fetch the refund transaction details with the clientRequestId.",
      "responseSchema": "Refund"
    },
    "getRefundById": {
      "method": "GET",
      "path": "/v1/payments/refunds/{fdRefundId}",
      "description": "Fetch the refund transaction details with the refundId.",
      "responseSchema": "Refund"
    },
    "voidRefund": {
      "method": "POST",
      "path": "/v1/payments/refunds/{fdRefundId}/void",
      "description": "Used to cancel the refund.",
      "requestSchema": "VoidRequest",
      "responseSchema": "Refund"
    },
    "createRefundV2": {
      "method": "POST",
      "path": "/v2/payments/refunds",
      "description": "Execute a refund for a transaction (V2 standalone refund).",
      "requestSchema": "RefundRequest",
      "responseSchema": "Refund"
    },
    "createMultiSale": {
      "method": "POST",
      "path": "/v2/payments/multi-sales",
      "description": "Create multiple payment sale transactions.",
      "requestSchema": "MultiSaleRequest",
      "responseSchema": "MultiSale"
    }
  },
  "schemas": {
    "AuthRequest": {
      "type": "object",
      "description": "Authorization Request wrapper",
      "fields": [
        { "name": "fdCustomerId", "type": "string", "required": false, "description": "FD customer identifier tied to the vaulted accounts.", "example": "cuid-0987613457398475" },
        { "name": "membership", "type": "Membership", "required": false, "description": "Membership information for the user." },
        { "name": "externalCustomerId", "type": "string", "required": false, "description": "External customer id." },
        { "name": "authorization", "type": "Authorization", "required": false, "description": "Authorization details including amount, funding source, merchant info." },
        { "name": "deviceInfo", "type": "DeviceInfo", "required": false, "description": "Request origin device details." }
      ]
    },
    "Authorization": {
      "type": "object",
      "description": "Authorization information - can only be ONE funding source among account, credit, prepaid, ApplePay, etc.",
      "required": ["requestedAmount"],
      "fields": [
        { "name": "fdAuthorizationId", "type": "string", "required": false, "readOnly": true, "description": "Unique Identifier provided by payment platform for a payment authorization transaction.", "example": "8a34144657d0aa6e0157d3808ed000f2" },
        { "name": "authStatus", "type": "PaymentStatus", "required": false, "description": "Status of the payment authorization.", "enum": ["APPROVED", "DECLINED", "CANCELLED", "CHALLENGED", "PENDING", "FAILED"] },
        { "name": "transactionSubtype", "type": "string", "required": false, "description": "Indicates subtype of a given transaction for EBT, ie EBTCASH or EBTSNAP" },
        { "name": "merchantId", "type": "string", "required": false, "description": "Merchant identifier where the transaction is being performed.", "example": "M117008616001" },
        { "name": "altMerchantId", "type": "string", "required": false, "description": "Alternate Merchant identifier.", "example": "23232" },
        { "name": "merchantTokenCode", "type": "string", "required": false, "description": "Merchant token code used for token generation" },
        { "name": "merchantTerminalId", "type": "string", "required": false, "description": "Merchant terminal identifier" },
        { "name": "storeId", "type": "string", "required": false, "description": "Store identifier where the transaction is being performed.", "example": "123456" },
        { "name": "outdoorSale", "type": "boolean", "required": false, "description": "Flag to indicate if the transaction is made outside the store.", "default": false },
        { "name": "exemptionCode", "type": "string", "required": false, "description": "Exemption code for 3DS transaction" },
        { "name": "transactionOrigin", "type": "string", "required": false, "description": "Transaction origin details.", "enum": ["ECOM", "MOTO", "POS"] },
        { "name": "requestedAmount", "type": "number", "required": true, "description": "Requested amount for the given request type in lower denomination.", "format": "double", "example": 500.00 },
        { "name": "approvedAmount", "type": "number", "required": false, "readOnly": true, "description": "Amount authorized. Read-only on payment requests; required for void.", "format": "double", "example": 500.00 },
        { "name": "currencyCode", "type": "ISO-4217", "required": false, "description": "Currency information with code (e.g. USD) and number (e.g. 840)." },
        { "name": "dynamicDescriptors", "type": "DynamicDescriptors", "required": false, "description": "Dynamic descriptor information including merchantCategoryCode, merchantName, merchantEmail." },
        { "name": "partialPaymentAllowed", "type": "boolean", "required": false, "description": "Flag that indicates if partial transaction is allowed or not" },
        { "name": "fundingSource", "type": "FundingSource", "required": false, "description": "Holds information about funding source for the payment transaction." },
        { "name": "purchaseInfo", "type": "array<PurchaseInfo>", "required": false, "description": "Purchase/order information including items." },
        { "name": "isSplitSettlement", "type": "boolean", "required": false, "description": "Indicates if this is a split settlement transaction" },
        { "name": "splitSettlementInfo", "type": "array<SplitSettlementInfo>", "required": false, "description": "Split funding information with beneficiaryName, beneficiaryId, amount." },
        { "name": "transactionDateTime", "type": "string", "required": false, "readOnly": true, "description": "Date and time of the transaction.", "format": "date-time", "example": "2016-04-16T16:06:05Z" },
        { "name": "createdDateTime", "type": "string", "required": false, "readOnly": true, "description": "Date and time of resource creation.", "format": "date-time" },
        { "name": "lastUpdatedDateTime", "type": "string", "required": false, "readOnly": true, "description": "Last updated Date and time of resource.", "format": "date-time" },
        { "name": "hostExtraInfo", "type": "array<NVP>", "required": false, "description": "Host extra info as name-value pairs." },
        { "name": "threeDSecureInfo", "type": "ThreeDSecure", "required": false, "description": "Details of 3D Secure transaction used to process the challenge flow." },
        { "name": "fleetData", "type": "FleetData", "required": false, "description": "Fleet data segment for fleet card transaction requests." },
        { "name": "captures", "type": "array<Capture>", "required": false, "readOnly": true, "description": "Array of captures associated with the payment authorization." },
        { "name": "errorInfo", "type": "Error", "required": false, "description": "Error information if applicable." }
      ]
    },
    "CaptureRequest": {
      "type": "object",
      "description": "Capture Request wrapper",
      "fields": [
        { "name": "fdCustomerId", "type": "string", "required": false, "description": "FD customer identifier tied to the vaulted accounts." },
        { "name": "membership", "type": "Membership", "required": false, "description": "Membership information for the user." },
        { "name": "externalCustomerId", "type": "string", "required": false, "description": "External customer id." },
        { "name": "capture", "type": "Capture", "required": false, "description": "Capture details." },
        { "name": "deviceInfo", "type": "DeviceInfo", "required": false, "description": "Request origin device details." }
      ]
    },
    "Capture": {
      "type": "object",
      "description": "Information related to make a capture on a previous authorization. When requested amount not provided the full authorized amount will be applied for capture.",
      "fields": [
        { "name": "fdCaptureId", "type": "string", "required": false, "readOnly": true, "description": "Unique identifier provided for a payment capture.", "example": "cap4144657d0aa6e0157d3808ed000f2" },
        { "name": "status", "type": "PaymentStatus", "required": false, "description": "Status of the payment capture.", "enum": ["APPROVED", "DECLINED", "CANCELLED", "CHALLENGED", "PENDING", "FAILED"] },
        { "name": "requestedAmount", "type": "number", "required": false, "description": "Requested amount for capture in lower denomination.", "format": "double", "example": 500.00 },
        { "name": "approvedAmount", "type": "number", "required": false, "description": "Amount approved for capture.", "format": "double", "example": 500.00 },
        { "name": "currencyCode", "type": "ISO-4217", "required": false, "description": "Currency information." },
        { "name": "dynamicDescriptors", "type": "DynamicDescriptors", "required": false, "description": "Dynamic descriptor information." },
        { "name": "transactionSubtype", "type": "string", "required": false, "description": "Indicates subtype of a given transaction for EBT" },
        { "name": "captureCount", "type": "integer", "required": false, "description": "Current capture count among the required ones. Required only for multi capture transactions.", "example": 1 },
        { "name": "captureTotalCount", "type": "integer", "required": false, "description": "Total captures intended to be processed in the authorization. Required only for multi capture.", "example": 2 },
        { "name": "splitSettlementInfo", "type": "array<SplitSettlementInfo>", "required": false, "description": "Split funding information." },
        { "name": "purchaseInfo", "type": "array<PurchaseInfo>", "required": false, "description": "Purchase/order information including items." },
        { "name": "transactionDateTime", "type": "string", "required": false, "readOnly": true, "description": "Date and time of the transaction.", "format": "date-time" },
        { "name": "createdDateTime", "type": "string", "required": false, "readOnly": true, "description": "Date and time of resource creation.", "format": "date-time" },
        { "name": "lastUpdatedDateTime", "type": "string", "required": false, "readOnly": true, "description": "Last updated date and time.", "format": "date-time" },
        { "name": "hostExtraInfo", "type": "array<NVP>", "required": false, "description": "Host extra info as name-value pairs." },
        { "name": "refunds", "type": "array<Refund>", "required": false, "readOnly": true, "description": "Array of refunds associated with the payment capture." }
      ]
    },
    "RefundRequest": {
      "type": "object",
      "description": "Refund Request wrapper",
      "fields": [
        { "name": "fdCustomerId", "type": "string", "required": false, "description": "FD customer identifier tied to the vaulted accounts." },
        { "name": "membership", "type": "Membership", "required": false, "description": "Membership information for the user." },
        { "name": "externalCustomerId", "type": "string", "required": false, "description": "External customer id." },
        { "name": "refund", "type": "Refund", "required": false, "description": "Refund details." },
        { "name": "deviceInfo", "type": "DeviceInfo", "required": false, "description": "Request origin device details." }
      ]
    },
    "Refund": {
      "type": "object",
      "description": "Information related to a refund. Requested amount to refund in lower denomination.",
      "fields": [
        { "name": "fdRefundId", "type": "string", "required": false, "readOnly": true, "description": "Unique identifier provided for a refund.", "example": "9a34144657d0aa6e0157d3808ed000f2" },
        { "name": "fdTransactionId", "type": "string", "required": false, "description": "Unique identifier for sale/capture.", "example": "9a34144657d0aa6e0157d3808ed000f2" },
        { "name": "externalId", "type": "string", "required": false, "description": "External transaction id reference" },
        { "name": "merchantId", "type": "string", "required": false, "description": "Merchant identifier where the transaction is being performed.", "example": "M117008616001" },
        { "name": "altMerchantId", "type": "string", "required": false, "description": "Alternate Merchant identifier.", "example": "23232" },
        { "name": "storeId", "type": "string", "required": false, "description": "Store identifier where the transaction is being performed.", "example": "123456" },
        { "name": "merchantTokenCode", "type": "string", "required": false, "description": "Merchant token code used for token generation" },
        { "name": "merchantTerminalId", "type": "string", "required": false, "description": "Merchant terminal identifier" },
        { "name": "merchantTransactionId", "type": "string", "required": false, "description": "Merchant transaction id" },
        { "name": "status", "type": "PaymentStatus", "required": false, "description": "Status of the refund.", "enum": ["APPROVED", "DECLINED", "CANCELLED", "CHALLENGED", "PENDING", "FAILED"] },
        { "name": "requestedAmount", "type": "number", "required": false, "description": "Requested amount for refund in lower denomination.", "format": "double", "example": 500.00 },
        { "name": "approvedAmount", "type": "number", "required": false, "description": "Amount approved for refund.", "format": "double", "example": 500.00 },
        { "name": "currencyCode", "type": "ISO-4217", "required": false, "description": "Currency information." },
        { "name": "fundingSource", "type": "FundingSource", "required": false, "description": "Funding source for the refund." },
        { "name": "dynamicDescriptors", "type": "DynamicDescriptors", "required": false, "description": "Dynamic descriptor information." },
        { "name": "purchaseInfo", "type": "array<PurchaseInfo>", "required": false, "description": "Purchase/order information." },
        { "name": "postDate", "type": "string", "required": false, "description": "Settlement date for the transaction. Format: MMDDYYYY", "format": "date" },
        { "name": "transactionDateTime", "type": "string", "required": false, "readOnly": true, "description": "Date and time of the transaction.", "format": "date-time" },
        { "name": "createdDateTime", "type": "string", "required": false, "readOnly": true, "description": "Date and time of resource creation.", "format": "date-time" },
        { "name": "lastUpdatedDateTime", "type": "string", "required": false, "readOnly": true, "description": "Last updated date and time.", "format": "date-time" },
        { "name": "hostExtraInfo", "type": "array<NVP>", "required": false, "description": "Host extra info as name-value pairs." }
      ]
    },
    "SaleRequest": {
      "type": "object",
      "description": "Sale Request wrapper",
      "fields": [
        { "name": "fdCustomerId", "type": "string", "required": false, "description": "FD customer identifier tied to the vaulted accounts." },
        { "name": "membership", "type": "Membership", "required": false, "description": "Membership information for the user." },
        { "name": "externalCustomerId", "type": "string", "required": false, "description": "External customer id." },
        { "name": "sale", "type": "Sale", "required": false, "description": "Sale details." },
        { "name": "deviceInfo", "type": "DeviceInfo", "required": false, "description": "Request origin device details." }
      ]
    },
    "Sale": {
      "type": "object",
      "description": "Information related to a SALE transaction - can only be ONE funding source.",
      "required": ["requestedAmount"],
      "fields": [
        { "name": "fdSaleId", "type": "string", "required": false, "readOnly": true, "description": "Unique Identifier provided by payment platform for a sale transaction.", "example": "8a34144657d0aa6e0157d3808ed000f2" },
        { "name": "rankId", "type": "string", "required": false, "description": "rankId is a required field when splitByRankId is true" },
        { "name": "externalId", "type": "string", "required": false, "description": "External transaction id reference" },
        { "name": "status", "type": "PaymentStatus", "required": false, "description": "Status of the sale.", "enum": ["APPROVED", "DECLINED", "CANCELLED", "CHALLENGED", "PENDING", "FAILED"] },
        { "name": "transactionSubtype", "type": "string", "required": false, "description": "Indicates subtype of a given transaction for EBT" },
        { "name": "merchantId", "type": "string", "required": false, "description": "Merchant identifier where the transaction is being performed.", "example": "M117008616001" },
        { "name": "altMerchantId", "type": "string", "required": false, "description": "Alternate Merchant identifier.", "example": "23232" },
        { "name": "storeId", "type": "string", "required": false, "description": "Store identifier.", "example": "123456" },
        { "name": "merchantTokenCode", "type": "string", "required": false, "description": "Merchant token code used for token generation" },
        { "name": "merchantTerminalId", "type": "string", "required": false, "description": "Merchant terminal identifier" },
        { "name": "merchantTransactionId", "type": "string", "required": false, "description": "Merchant transaction id" },
        { "name": "exemptionCode", "type": "string", "required": false, "description": "Exemption code for 3DS transaction" },
        { "name": "transactionOrigin", "type": "string", "required": false, "description": "Transaction origin details.", "enum": ["ECOM", "MOTO", "POS"] },
        { "name": "requestedAmount", "type": "number", "required": true, "description": "Requested amount in lower denomination.", "format": "double", "example": 500.00 },
        { "name": "approvedAmount", "type": "number", "required": false, "readOnly": true, "description": "Amount approved.", "format": "double", "example": 500.00 },
        { "name": "currencyCode", "type": "ISO-4217", "required": false, "description": "Currency information." },
        { "name": "dynamicDescriptors", "type": "DynamicDescriptors", "required": false, "description": "Dynamic descriptor information." },
        { "name": "postDate", "type": "string", "required": false, "description": "Settlement date for the transaction. Format: MMDDYYYY", "format": "date" },
        { "name": "partialPaymentAllowed", "type": "boolean", "required": false, "description": "Flag that indicates if partial transaction is allowed" },
        { "name": "fundingSource", "type": "FundingSource", "required": false, "description": "Funding source for the sale." },
        { "name": "isSplitSettlement", "type": "boolean", "required": false, "description": "Indicates if this is a split settlement transaction" },
        { "name": "splitSettlementInfo", "type": "array<SplitSettlementInfo>", "required": false, "description": "Split funding information." },
        { "name": "purchaseInfo", "type": "array<PurchaseInfo>", "required": false, "description": "Purchase/order information." },
        { "name": "transactionDateTime", "type": "string", "required": false, "readOnly": true, "description": "Date and time of the transaction.", "format": "date-time" },
        { "name": "createdDateTime", "type": "string", "required": false, "readOnly": true, "description": "Date and time of resource creation.", "format": "date-time" },
        { "name": "lastUpdatedDateTime", "type": "string", "required": false, "readOnly": true, "description": "Last updated date and time.", "format": "date-time" },
        { "name": "hostExtraInfo", "type": "array<NVP>", "required": false, "description": "Host extra info as name-value pairs." },
        { "name": "threeDSecureInfo", "type": "ThreeDSecure", "required": false, "description": "3D Secure transaction details." },
        { "name": "fleetData", "type": "FleetData", "required": false, "description": "Fleet data segment." },
        { "name": "errorInfo", "type": "Error", "required": false, "description": "Error information if applicable." }
      ]
    },
    "VoidRequest": {
      "type": "object",
      "description": "Void Request wrapper",
      "fields": [
        { "name": "fdCustomerId", "type": "string", "required": false, "description": "FD customer identifier tied to the vaulted accounts." },
        { "name": "membership", "type": "Membership", "required": false, "description": "Membership information for the user." },
        { "name": "externalCustomerId", "type": "string", "required": false, "description": "External customer id." },
        { "name": "deviceInfo", "type": "DeviceInfo", "required": false, "description": "Request origin device details." },
        { "name": "void", "type": "Void", "required": false, "description": "Void details." }
      ]
    },
    "Void": {
      "type": "object",
      "description": "Information related to a void.",
      "fields": [
        { "name": "fdTransactionId", "type": "string", "required": false, "description": "Unique identifier provided for sale/capture/refund.", "example": "9a34144657d0aa6e0157d3808ed000f2" },
        { "name": "externalId", "type": "string", "required": false, "description": "External transaction id reference" },
        { "name": "merchantTransactionId", "type": "string", "required": false, "description": "Merchant transaction id" },
        { "name": "approvedAmount", "type": "number", "required": false, "description": "Amount approved for void.", "format": "double" },
        { "name": "transactionDateTime", "type": "string", "required": false, "readOnly": true, "description": "Date and time of the transaction.", "format": "date-time" },
        { "name": "storeId", "type": "string", "required": false, "description": "Store identifier.", "example": "123456" },
        { "name": "currencyCode", "type": "ISO-4217", "required": false, "description": "Currency information." },
        { "name": "hostExtraInfo", "type": "array<NVP>", "required": false, "description": "Host extra info as name-value pairs." },
        { "name": "dynamicDescriptors", "type": "DynamicDescriptors", "required": false, "description": "Dynamic descriptor information." },
        { "name": "fundingSource", "type": "FundingSource", "required": false, "description": "Funding source information." },
        { "name": "purchaseInfo", "type": "array<PurchaseInfo>", "required": false, "description": "Purchase/order information." }
      ]
    },
    "FundingSource": {
      "type": "object",
      "description": "Holds information about funding source for the payment transaction. Can hold only one of the provided funding sources.",
      "fields": [
        { "name": "saveToVault", "type": "boolean", "required": false, "description": "Flag to indicate if the payment method should be vaulted for future use.", "default": false },
        { "name": "type", "type": "FundingSourceType", "required": false, "description": "Describes the type of Funding source.", "enum": ["VAULTED_ACCOUNT", "CREDIT", "PREPAID", "APPLE_PAY", "PAYPAL", "TOKEN", "NONCE", "VCO", "VENMO", "AMAZON_PAY", "VIPPS", "FLEET", "BANCONTACT", "IDEAL", "WALMART_PAY", "EBT", "ACH"] },
