        { "name": "billingPhone", "type": "Phone", "required": false, "description": "Billing phone number." },
        { "name": "expiryDate", "type": "ExpiryDate", "required": false, "description": "Card expiration date with month (MM) and year (YY) or singleValue (MMYY/MMYYYY)." },
        { "name": "securityCode", "type": "string", "required": false, "description": "Card security code (CVV/CVC).", "example": "444" },
        { "name": "sequenceNumber", "type": "string", "required": false, "description": "Applicable only for private-label accounts", "example": "01" },
        { "name": "token", "type": "ReferenceToken", "required": false, "description": "Reference token for the credit card." },
        { "name": "tokens", "type": "array<ReferenceToken>", "required": false, "description": "Array of reference tokens." }
      ]
    },
    "Address": {
      "type": "object",
