          "required": true,
          "notes": "Must add CASHAPP to FundingSourceType enum"
        },
        {
          "source": "authorization.fundingSource.cashApp.grantId",
          "sourceType": "string",
          "target": "paymentMethod.paymentToken.tokenData",
          "targetType": "string",
