        },
        {
          "source": "[header] Client-Request-Id",
          "sourceType": "string",
          "target": "[header] Client-Request-Id",
          "targetType": "string",
          "transform": "PASSTHROUGH",
          "required": true
        },
        {
          "source": "[header] Api-Key",
