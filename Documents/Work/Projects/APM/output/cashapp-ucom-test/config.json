          "target": "amount.currency",
          "targetType": "string",
          "transform": "PASSTHROUGH",
          "required": true
        },
        {
          "source": "{fdAuthorizationId}",
          "sourceType": "string",
          "target": "referenceTransactionDetails.referenceTransactionId",
          "targetType": "string",
          "transform": "PASSTHROUGH",
          "required": true,
          "notes": "Path parameter to body field"
        },
        {
          "source": "capture.merchantId",
          "sourceType": "string",
          "target": "merchantDetails.merchantId",
          "targetType": "string",
          "transform": "PASSTHROUGH",
          "required": true
        },
        {
