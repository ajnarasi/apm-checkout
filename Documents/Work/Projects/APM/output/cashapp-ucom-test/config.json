        {
          "source": "transactionProcessingDetails.transactionId",
          "sourceType": "string",
          "target": "capture.fdCaptureId",
          "targetType": "string",
          "transform": "PASSTHROUGH"
        },
        {
          "source": "gatewayResponse.transactionState",
          "sourceType": "string",
          "target": "capture.captureStatus",
          "targetType": "string",
          "transform": "MAP_ENUM",
          "enumMap": { "CAPTURED": "APPROVED", "DECLINED": "DECLINED" }
        },
        {
          "source": "paymentReceipt.approvedAmount.total",
          "sourceType": "number",
          "target": "capture.approvedAmount",
          "targetType": "number",
          "transform": "NONE"
        },
        {
          "source": "paymentReceipt.processorResponseDetails.approvalCode",
          "sourceType": "string",
          "target": "capture.approvalCode",
          "targetType": "string",
          "transform": "PASSTHROUGH"
        },
        {
          "source": "transactionProcessingDetails.transactionTimestamp",
          "sourceType": "string",
          "target": "capture.transactionDateTime",
          "targetType": "string",
          "transform": "PASSTHROUGH"
        }
