        },
        {
          "source": "transactionProcessingDetails.transactionTimestamp",
          "sourceType": "string",
          "target": "authorization.transactionDateTime",
          "targetType": "string",
          "transform": "PASSTHROUGH",
          "notes": "ISO-8601"
        }
      ]
    },
    "capture": {
      "request": [
