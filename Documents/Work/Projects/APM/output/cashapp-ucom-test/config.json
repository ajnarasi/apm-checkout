  },
  "conditionalRouting": {
    "SCOPE_TYPE_ROUTE": {
      "description": "Routes CashApp transactions based on scope type to correct Commerce Hub processing path",
      "rules": [
        {
          "condition": "paymentMethod.provider == 'CASHAPP' AND transactionDetails.operationType == 'AUTHORIZE'",
          "target": "checkouts/v1/orders",
          "method": "POST",
          "headers": { "Content-Type": "application/json" }
        },
        {
          "condition": "paymentMethod.provider == 'CASHAPP' AND transactionDetails.captureFlag == true",
          "target": "checkouts/v1/orders",
          "method": "POST",
          "headers": { "Content-Type": "application/json" },
          "notes": "Capture requires referenceTransactionId from prior auth"
        },
        {
          "condition": "paymentMethod.provider == 'CASHAPP' AND transactionDetails.operationType == 'REFUND'",
          "target": "checkouts/v1/orders",
          "method": "POST",
          "headers": { "Content-Type": "application/json" },
          "notes": "Refund requires referenceTransactionId from prior capture"
        }
      ]
    }
  },
  "authScheme": {
    "type": "HMAC",
    "algorithm": "HMAC-SHA256",
    "headers": {
      "Api-Key": { "source": "credential-vault", "required": true },
      "Timestamp": { "source": "generated", "format": "epoch-ms", "required": true },
      "Auth-Token-Type": { "source": "static", "value": "HMAC", "required": true },
      "Client-Request-Id": { "source": "passthrough-or-generated", "format": "uuid", "required": true },
      "Authorization": { "source": "computed", "required": true }
    },
    "signatureMessage": "Api-Key + Client-Request-Id + Timestamp + RequestBody",
    "signatureEncoding": "Base64"
  },
  "lifecycle": {
    "pattern": "redirect-wallet",
    "steps": [
      {
        "step": 1,
        "name": "INITIALIZE",
        "description": "Create order with CashApp as payment method",
        "endpoint": "POST /checkouts/v1/orders",
        "expectedState": "PAYER_ACTION_REQUIRED"
      },
      {
        "step": 2,
        "name": "REDIRECT",
        "description": "Redirect customer to CashApp for approval",
        "source": "checkoutInteractions.actions.url",
        "alternative": "checkoutInteractions.actions.code (QR code)",
        "expectedState": "PAYER_ACTION_REQUIRED"
      },
      {
        "step": 3,
        "name": "CUSTOMER_APPROVAL",
        "description": "Customer approves payment in CashApp",
        "externalFlow": true,
        "callbackUrl": "checkoutInteractions.returnUrls.successUrl"
      },
      {
        "step": 4,
        "name": "AUTHORIZE",
        "description": "Commerce Hub confirms authorization after customer approval",
        "expectedState": "AUTHORIZED"
      },
      {
        "step": 5,
        "name": "CAPTURE",
        "description": "Capture the authorized amount",
        "endpoint": "POST /checkouts/v1/orders",
        "expectedState": "CAPTURED",
        "optional": true,
        "notes": "Required only for auth-then-capture flows; sale flows auto-capture"
      },
      {
        "step": 6,
        "name": "REFUND",
        "description": "Refund captured amount (full or partial)",
        "endpoint": "POST /checkouts/v1/orders",
        "expectedState": "REFUNDED",
        "optional": true
      }
    ],
    "timeouts": {
      "customerApprovalWindowMs": 900000,
      "authToCaptureTtlMs": 604800000,
      "notes": "15 min customer approval window; 7 day auth-to-capture TTL"
    }
  },
  "safetyChecks": {
    "amountSymmetry": "PASS",
    "currencyPreservation": "PASS",
    "idUniqueness": "PASS_WITH_NOTE",
    "idUniquenessNote": "providerOrderId uses GRR_ prefix; fdAuthorizationId is CH-generated transactionId",
    "tier1Coverage": "PASS",
    "tier1CoverageNote": "All Tier-1 fields (amount, currency, merchantId, transactionId, status) mapped bidirectionally",
    "bidirectionalCompleteness": "PASS",
    "bidirectionalCompletenessNote": "10 request + 11 response fields mapped for auth; capture and refund follow same pattern",
    "returnUrlValidation": "PASS",
    "returnUrlValidationNote": "redirectUrl and qrCodeUrl both passed through from checkoutInteractions.actions"
  }
}