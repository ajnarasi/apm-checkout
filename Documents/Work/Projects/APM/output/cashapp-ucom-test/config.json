        {
          "source": "gatewayResponse.transactionProcessingDetails.orderId",
          "sourceType": "string",
          "target": "authorization.orderId",
          "targetType": "string",
          "transform": "PASSTHROUGH"
        },
        {
          "source": "paymentReceipt.processorResponseDetails.approvalCode",
          "sourceType": "string",
